{
  "name": "DeepSeek Code Theme",
  "type": "dark",
  "author": "Generated from DeepSeek conversation",
  "description": "Syntax highlighting theme based on the colors used in DeepSeek code blocks",
  
  "fonts": {
    "code": {
      "primary": "JetBrains Mono",
      "fallback": ["Fira Code", "monospace"],
      "weights": [400, 500, 600],
      "source": "https://fonts.google.com/specimen/JetBrains+Mono",
      "license": "SIL Open Font License",
      "cssImport": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap",
      "cssRule": "font-family: 'JetBrains Mono', 'Fira Code', monospace;"
    },
    "ui": {
      "primary": "Inter",
      "fallback": ["system-ui", "-apple-system", "Segoe UI", "sans-serif"],
      "weights": [400, 500, 600, 700],
      "source": "https://rsms.me/inter/",
      "license": "SIL Open Font License",
      "cssImport": "https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap",
      "cssRule": "font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;"
    },
    "monoAlternatives": ["Fira Code", "Source Code Pro", "Cascadia Code", "Monaco", "Consolas"]
  },

  "colors": {
    "background": "#0a0a0f",
    "backgroundSecondary": "#12121a",
    "editorBackground": "#1a1a24",
    "textPrimary": "#ededee",
    "textSecondary": "#9ca3af",
    "border": "#2a2a35",
    
    "syntax": {
      "comment": "#6a737d",
      "keyword": "#ff7b72",
      "function": "#d2a8ff",
      "variable": "#79c0ff",
      "string": "#a5d6ff",
      "number": "#79c0ff",
      "operator": "#ff7b72",
      "punctuation": "#e4e4e7",
      "property": "#79c0ff",
      "tag": "#7ee787",
      "attribute": "#79c0ff",
      "selector": "#d2a8ff",
      "value": "#a5d6ff"
    },
    
    "specific": {
      "cssProperty": "#ff7b72",
      "cssValue": "#a5d6ff",
      "htmlTag": "#7ee787",
      "htmlAttribute": "#79c0ff",
      "javascriptConst": "#79c0ff",
      "javascriptLet": "#79c0ff",
      "javascriptFunction": "#d2a8ff",
      "javascriptReturn": "#ff7b72"
    },
    
    "ui": {
      "accent": "#3b82f6",
      "accentHover": "#60a5fa",
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "lineNumber": "#52525b"
    },
    
    "gradients": {
      "headerGradient": ["#3b82f6", "#8b5cf6", "#ec489a"],
      "cardGradient": ["#1a1a24", "#12121a"]
    }
  },
  
  "editor": {
    "fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
    "fontSize": "13px",
    "lineHeight": 1.5,
    "letterSpacing": "normal",
    "fontLigatures": true
  },
  
  "tokenColors": [
    {
      "name": "Comment",
      "scope": "comment",
      "settings": { "foreground": "#6a737d", "fontStyle": "italic" }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": { "foreground": "#a5d6ff" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.parameter"],
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "name": "CSS Property",
      "scope": "support.type.property-name.css",
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "name": "CSS Value",
      "scope": "support.constant.property-value.css",
      "settings": { "foreground": "#a5d6ff" }
    },
    {
      "name": "HTML Tag",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#7ee787" }
    },
    {
      "name": "HTML Attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "name": "JSON Key",
      "scope": "support.type.property-name.json",
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "name": "JSON Value",
      "scope": "string.value.json",
      "settings": { "foreground": "#a5d6ff" }
    }
  ],
  
  "semanticHighlighting": true,
  
  "colorFormats": {
    "hex": {
      "background": "#0a0a0f",
      "accent": "#3b82f6",
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444"
    },
    "rgb": {
      "background": "rgb(10, 10, 15)",
      "accent": "rgb(59, 130, 246)",
      "success": "rgb(16, 185, 129)",
      "warning": "rgb(245, 158, 11)",
      "error": "rgb(239, 68, 68)"
    },
    "hsl": {
      "background": "hsl(240, 20%, 5%)",
      "accent": "hsl(217, 91%, 60%)",
      "success": "hsl(152, 84%, 45%)",
      "warning": "hsl(38, 92%, 50%)",
      "error": "hsl(0, 84%, 60%)"
    }
  },
  
  "cssVariables": {
    "dark": {
      "--bg-primary": "#0a0a0f",
      "--bg-secondary": "#12121a",
      "--card-bg": "#1a1a24",
      "--text-primary": "#ededee",
      "--text-secondary": "#9ca3af",
      "--accent": "#3b82f6",
      "--border": "#2a2a35"
    },
    "fontCssVariables": {
      "--font-code": "'JetBrains Mono', 'Fira Code', monospace",
      "--font-ui": "'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif"
    }
  },
  
  "themeCompatibility": {
    "vscode": "One Dark Pro (similar)",
    "sublime": "One Dark",
    "intellij": "Darcula with modifications",
    "atom": "One Dark"
  },
  
  "exportDate": "2026-04-02",
  "version": "1.1.0"
}