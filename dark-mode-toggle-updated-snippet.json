{
  "Dark Mode Toggle with Browser Sync & LocalStorage": {
    "prefix": "darkmode",
    "scope": "html,javascriptreact,typescriptreact,javascript,typescript",
    "body": [
      "// Dark Mode Toggle with Browser Sync & LocalStorage",
      "// Pure CSS + JavaScript + Tailwind Integration",
      "",
      "// 1. Tailwind Config (add to tailwind.config.js):",
      "module.exports = {",
      "  darkMode: 'class', // Enable class-based dark mode",
      "  // ... rest of your config",
      "}",
      "",
      "",
      "// 2. CSS (add to your CSS file):",
      "/* Light mode variables */",
      ":root {",
      "  --bg-color: #fff;",
      "  --text-color: #333;",
      "  --card-bg: #ffffff;",
      "}",
      "",
      "/* Browser automatic dark mode */",
      "@media (prefers-color-scheme: dark) {",
      "  :root {",
      "    --bg-color: #16171d;",
      "    --text-color: #f1f5f9;",
      "    --card-bg: #1e2937;",
      "  }",
      "}",
      "",
      "/* Manual toggle dark mode */",
      "body {",
      "  background-color: var(--bg-color);",
      "  color: var(--text-color);",
      "  transition: background-color 0.3s ease, color 0.3s ease;",
      "}",
      "",
      "body.dark {",
      "  background-color: #16171d;",
      "  color: #f1f5f9;",
      "}",
      "",
      "body.dark nav, body.dark .card, body.dark .drop-menus {",
      "  background-color: #1e2937;",
      "  color: #f1f5f9;",
      "}",
      "",
      "",
      "// 3. JavaScript (add to your component):",
      "// Read localStorage on page load (pure JS)",
      "const hasDark = JSON.parse(localStorage.getItem('isDark') || 'false');",
      "if(hasDark){",
      "  document.body.classList.add('dark');",
      "  updateIcon();",
      "} else {",
      "  document.body.classList.remove('dark');",
      "  updateIcon();",
      "}",
      "",
      "// Update icon based on current state",
      "const updateIcon = () => {",
      "  const toggleIcon = document.querySelector('#toggle-icon');",
      "  const isDarkMode = document.body.classList.contains('dark');",
      "  ",
      "  if (isDarkMode) {",
      "    // Moon icon",
      "    toggleIcon?.setAttribute(\"d\", \"M9.528 1.718a.75.75 0 0 1 .162.819A8.97 8.97 0 0 0 9 6a9 9 0 0 0 9 9 8.97 8.97 0 0 0 3.463-.69.75.75 0 0 1 .981.98 10.503 10.503 0 0 1-9.694 6.46c-5.799 0-10.5-4.7-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 0 1 .818.162Z\")",
      "  } else {",
      "    // Sun icon",
      "    toggleIcon?.setAttribute(\"d\", \"M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.758 17.303a.75.75 0 0 0-1.061-1.06l-1.591 1.59a.75.75 0 0 0 1.06 1.061l1.591-1.59ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.697 7.757a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 0 0-1.061 1.06l1.59 1.591Z\")",
      "  }",
      "};",
      "",
      "// Listen for browser preference changes",
      "window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {",
      "  if (e.matches) {",
      "    document.body.classList.add('dark');",
      "  } else {",
      "    document.body.classList.remove('dark');",
      "  }",
      "  updateIcon(); // Update icon when browser changes",
      "});",
      "",
      "// Initialize on page load",
      "if (window.matchMedia('(prefers-color-scheme: dark)').matches) {",
      "  document.body.classList.add('dark');",
      "}",
      "updateIcon(); // Set correct icon on load",
      "",
      "// Toggle function with localStorage",
      "const toggleButton = () => {",
      "  document.body.classList.toggle(\"dark\");",
      "  // Save to localStorage",
      "  if (document.body.classList.contains(\"dark\")) {",
      "    localStorage.setItem(\"isDark\", 'true');",
      "  } else {",
      "    localStorage.setItem(\"isDark\", 'false');",
      "  }",
      "  updateIcon(); // Update icon when user toggles",
      "};",
      "",
      "",
      "// 4. HTML (add to your JSX/HTML):",
      "<button onClick={toggleButton}>",
      "  <svg",
      "    xmlns=\"http://www.w3.org/2000/svg\"",
      "    viewBox=\"0 0 24 24\"",
      "    fill=\"currentColor\"",
      "    className=\"cursor-pointer hover:rotate-90 transition size-6\"",
      "  >",
      "    <path id=\"toggle-icon\" d=\"M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.758 17.303a.75.75 0 0 0-1.061-1.06l-1.591 1.59a.75.75 0 0 0 1.06 1.061l1.591-1.59ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.697 7.757a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 0 0-1.061 1.06l1.59 1.591Z\" />",
      "  </svg>",
      "</button>",
      "",
      "",
      "// 5. Tailwind Usage Examples:",
      "<div className='w-20 h-20 bg-red-400 dark:bg-rose-700'></div>",
      "<nav className='bg-white dark:bg-gray-800 text-black dark:text-white'>",
      "<button className='px-4 py-2 bg-blue-500 dark:bg-blue-700 text-white dark:hover:bg-blue-600'>",
      "",
      "",
      "// 6. Features:",
      "// ✅ Browser dark mode detection",
      "// ✅ Manual toggle button",
      "// ✅ Icon switching (sun/moon)",
      "// ✅ Browser preference sync",
      "// ✅ LocalStorage persistence",
      "// ✅ Tailwind CSS integration",
      "// ✅ Smooth transitions",
      "// ✅ Pure CSS + JavaScript (no frameworks needed)",
      "",
      "// Usage: Type 'darkmode' in VS Code to insert this complete solution"
    ],
    "description": "Complete dark mode toggle with browser sync, localStorage, and Tailwind integration - pure CSS + JavaScript solution"
  }
